// --- Motor Driver Pins (L298N) ---
// Motor A (Right Motor)
const int enA = 10; // PWM pin for speed control
const int in1 = 9;  // Direction control
const int in2 = 8;  // Direction control

// Motor B (Left Motor)
const int enB = 5;  // PWM pin for speed control
const int in3 = 7;  // Direction control
const int in4 = 6;  // Direction control

// --- IR Sensor Pins ---
// Assuming digital output: HIGH (1) for white floor, LOW (0) for black line
const int irLeft = 2;
const int irCenter = 3;
const int irRight = 4;

// --- Speed Settings ---
const int baseSpeed = 150; // Adjust between 0-255
const int turnSpeed = 180; // Slightly higher for overcoming friction in turns

void setup() {
  // Initialize Motor Pins
  pinMode(enA, OUTPUT);
  pinMode(in1, OUTPUT);
  pinMode(in2, OUTPUT);
  
  pinMode(enB, OUTPUT);
  pinMode(in3, OUTPUT);
  pinMode(in4, OUTPUT);

  // Initialize Sensor Pins
  pinMode(irLeft, INPUT);
  pinMode(irCenter, INPUT);
  pinMode(irRight, INPUT);

  // Initial state: Motors stopped
  stopMotors();
}

void loop() {
  // Read sensor values
  int leftVal = digitalRead(irLeft);
  int centerVal = digitalRead(irCenter);
  int rightVal = digitalRead(irRight);

  // Logic for Black Line on White Surface
  // Assuming sensor reads LOW (0) when detecting the black line

  if (leftVal == HIGH && centerVal == LOW && rightVal == HIGH) {
    // Only center sensor detects line -> Move Forward
    moveForward();
  } 
  else if (leftVal == LOW && centerVal == HIGH && rightVal == HIGH) {
    // Left sensor detects line -> Turn Left
    turnLeft();
  } 
  else if (leftVal == LOW && centerVal == LOW && rightVal == HIGH) {
    // Left and center detect line (sharp left) -> Turn Left
    turnLeft();
  }
  else if (leftVal == HIGH && centerVal == HIGH && rightVal == LOW) {
    // Right sensor detects line -> Turn Right
    turnRight();
  } 
  else if (leftVal == HIGH && centerVal == LOW && rightVal == LOW) {
    // Right and center detect line (sharp right) -> Turn Right
    turnRight();
  }
  else if (leftVal == HIGH && centerVal == HIGH && rightVal == HIGH) {
    // Lost the line -> Stop (or you can program it to reverse/search)
    stopMotors();
  }
}

// --- Movement Functions ---

void moveForward() {
  analogWrite(enA, baseSpeed);
  analogWrite(enB, baseSpeed);
  
  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}

void turnLeft() {
  analogWrite(enA, turnSpeed);
  analogWrite(enB, turnSpeed);
  
  // Right motor forward, Left motor backward (for tight zero-radius turn)
  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  digitalWrite(in3, LOW);
  digitalWrite(in4, HIGH);
}

void turnRight() {
  analogWrite(enA, turnSpeed);
  analogWrite(enB, turnSpeed);
  
  // Right motor backward, Left motor forward
  digitalWrite(in1, LOW);
  digitalWrite(in2, HIGH);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}

void stopMotors() {
  digitalWrite(in1, LOW);
  digitalWrite(in2, LOW);
  digitalWrite(in3, LOW);
  digitalWrite(in4, LOW);
}
